{
  "name": "decibell-native",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "decibell",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release --js index.js --dts index.d.ts && node ./copy-dlls.cjs",
    "build:debug": "napi build --platform --js index.js --dts index.d.ts && node ./copy-dlls.cjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  }
}
